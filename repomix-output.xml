            : prefill.__sourceCollection === "awaitingInfo"
              ? `${actorLabel()} העביר את אבידה מספר ${number} מ-${collectionLabel(prefill.__sourceCollection)} ל-${collectionLabel(COLLECTION)}`
              : `${actorLabel()} העביר את אבידה מספר ${number} מ-${collectionLabel(prefill.__sourceCollection)} ל-${collectionLabel(COLLECTION)}`,
