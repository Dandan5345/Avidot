:root {
  --bg: #f4f6f3;
  --bg-soft: #fbfaf7;
  --surface: rgba(255, 255, 255, 0.88);
  --surface-strong: #ffffff;
  --surface-alt: #f3f7fd;
  --line: rgba(88, 119, 168, 0.15);
  --line-strong: rgba(88, 119, 168, 0.24);
  --text: #1f2933;
  --text-soft: #58646f;
  --text-muted: #78838f;
  --primary: #58b8de;
  --primary-dark: #379dc8;
  --primary-soft: rgba(229, 248, 255, 0.9);
  --accent: #9cdcf5;
  --accent-soft: rgba(236, 250, 255, 0.94);
  --danger: #c03d3d;
  --danger-dark: #9c2929;
  --danger-soft: #fee7e5;
  --success: #168050;
  --success-soft: #def6ea;
  --shadow-sm: 0 10px 30px rgba(39, 43, 46, 0.06);
  --shadow-md: 0 18px 46px rgba(39, 43, 46, 0.1);
  --shadow-lg: 0 26px 70px rgba(28, 43, 46, 0.16);
  --radius-sm: 12px;
  --radius-md: 18px;
  --radius-lg: 28px;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  height: 100%;
}

body {
  margin: 0;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  font-family: "Heebo", "Assistant", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background:
    radial-gradient(circle at top right, rgba(156, 220, 245, 0.2), transparent 24%),
    radial-gradient(circle at top left, rgba(88, 184, 222, 0.14), transparent 22%),
    linear-gradient(180deg, #f9f6ef 0%, #f3f6f4 44%, #edf1f0 100%);
  color: var(--text);
  font-size: 15px;
  line-height: 1.45;
  overscroll-behavior-y: none;
  -webkit-font-smoothing: antialiased;
}

button,
input,
select,
textarea {
  font: inherit;
}

.hidden {
  display: none !important;
}

