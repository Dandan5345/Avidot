  box-shadow: 0 4px 20px rgba(31, 41, 51, 0.05);
  backdrop-filter: blur(20px) saturate(1.2);
  -webkit-backdrop-filter: blur(20px) saturate(1.2);
  transition: all 0.3s ease;
}

.topbar-center,
.topbar-left {
  display: flex;
