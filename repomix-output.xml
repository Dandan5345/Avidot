.home-card.modern-card {
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12px;
  min-height: 160px;
  padding: 20px 20px;
  border-radius: 28px;
  border: 1px solid rgba(255, 255, 255, 0.9);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(240, 251, 255, 0.85)),
    linear-gradient(135deg, rgba(88, 184, 222, 0.05), transparent 60%);
  box-shadow: 0 10px 30px rgba(31, 41, 51, 0.04);
  cursor: pointer;
  backdrop-filter: blur(12px);
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  animation: slideUp 0.5s ease both;
}

.home-card.modern-card:nth-child(2) {
