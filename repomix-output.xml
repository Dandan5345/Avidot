  background: var(--surface);
  box-shadow: 0 4px 24px rgba(31, 41, 51, 0.03);
  backdrop-filter: blur(16px);
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  padding: 10px 12px;
  margin-bottom: 12px;
}

.toolbar input[type="text"],
.toolbar input[type="date"] {
  flex: 1 1 190px;
  max-width: 240px;
}

.toolbar .checkbox-row {
  margin: 0;
}

.toolbar .spacer {
  flex: 1;
}

.table-wrap {
  overflow: auto;
}

table.data {
  width: 100%;
  min-width: 760px;
  border-collapse: separate;
  border-spacing: 0;
}

table.data th,
table.data td {
  padding: 12px 12px;
  text-align: right;
  border-bottom: 1px solid rgba(88, 119, 168, 0.1);
  vertical-align: middle;
}

table.data th {
  position: sticky;
  top: 0;
  z-index: 1;
  background: linear-gradient(180deg, #f6faff, #ebf3ff);
  color: #4d5963;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.03em;
  white-space: nowrap;
}

table.data tbody tr {
  background: rgba(255, 255, 255, 0.82);
  cursor: pointer;
  transition: background 0.18s ease, transform 0.18s ease;
}

table.data tbody tr:nth-child(even) {
  background: rgba(243, 248, 255, 0.78);
}

table.data tbody tr:hover {
  background: rgba(232, 242, 255, 0.98);
}

table.data tbody tr.returned {
  color: #7b858e;
  background: rgba(245, 247, 248, 0.92);
}

table.data tbody tr.returned:hover {
  background: rgba(237, 241, 243, 0.98);
}

table.data td:last-child {
  white-space: nowrap;
}

table.data td button {
  margin-inline-start: 6px;
  margin-block: 3px;
}

.empty {
  padding: 30px;
  text-align: center;
  color: var(--text-muted);
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 26px;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 800;
}

.badge.green {
  background: var(--success-soft);
  color: #186746;
}

.badge.red {
  background: var(--danger-soft);
  color: #922f2f;
}

.badge.amber {
  background: var(--accent-soft);
  color: #247398;
}

.badge.blue {
  background: rgba(230, 248, 255, 0.94);
  color: #216885;
}

.badge.purple {
  background: rgba(233, 247, 255, 0.94);
  color: #2a7090;
}

.modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  background: rgba(16, 37, 44, 0.25);
  backdrop-filter: blur(12px) saturate(1.2);
  animation: fadeIn 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.modal {
  width: 100%;
  max-width: 760px;
  max-height: min(94vh, 980px);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.9);
  border-radius: 32px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 252, 255, 0.96)),
    linear-gradient(135deg, rgba(88, 184, 222, 0.05), transparent 40%);
  box-shadow: 0 24px 64px rgba(20, 50, 60, 0.15), 0 0 0 1px rgba(255, 255, 255, 0.4) inset;
  animation: slideUp 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.modal.large {
  max-width: 940px;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 20px 24px;
  border-bottom: 1px solid rgba(88, 119, 168, 0.08);
  background: rgba(255, 255, 255, 0.4);
}

.modal-header h3 {
  margin: 0;
  font-size: 24px;
  font-weight: 800;
  color: #1f3b4d;
}

.modal-close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border: none;
  border-radius: 50%;
  background: rgba(88, 184, 222, 0.08);
  color: var(--text-soft);
  font-size: 24px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.modal-close:hover {
  background: rgba(192, 61, 61, 0.1);
  color: var(--danger);
  transform: rotate(90deg) scale(1.05);
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 18px;
}

.modal-body form {
  display: grid;
  gap: 14px;
}

.modal-body p {
  color: var(--text-soft);
}

.modal-note {
  display: grid;
  gap: 6px;
  padding: 16px 20px;
  border: 1px solid rgba(88, 184, 222, 0.2);
  border-radius: 20px;
  background:
    radial-gradient(circle at 100% 0%, rgba(20, 100, 130, 0.03), transparent 50%),
    rgba(240, 251, 255, 0.8);
  box-shadow: 0 4px 12px rgba(88, 184, 222, 0.05);
}

.modal-note strong {
  color: #1f3b4d;
  font-size: 15px;
  font-weight: 800;
}

.modal-note span {
  color: var(--text-soft);
  font-size: 13px;
  line-height: 1.6;
}

.compact-grid {
  gap: 10px;
}

.field-note {
  color: var(--text-muted);
  font-size: 11px;
  line-height: 1.45;
}

.signature-card {
  display: grid;
  gap: 10px;
  padding: 14px;
  border: 1px solid rgba(88, 184, 222, 0.16);
  border-radius: 22px;
  background:
    linear-gradient(180deg, rgba(233, 249, 255, 0.78), rgba(255, 255, 255, 0.94)),
    linear-gradient(135deg, rgba(156, 220, 245, 0.16), transparent 55%);
}

.signature-card-head {
  display: grid;
  gap: 4px;
}

.signature-card-head strong {
  color: #235b74;
  font-size: 15px;
}

.signature-card-head span {
  color: var(--text-soft);
  font-size: 12px;
  line-height: 1.55;
}

.signature-pad-shell {
  position: relative;
  min-height: 210px;
  border: 1px dashed rgba(88, 184, 222, 0.32);
  border-radius: 20px;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(241, 250, 255, 0.92)),
    repeating-linear-gradient(0deg, transparent, transparent 31px, rgba(88, 184, 222, 0.06) 31px, rgba(88, 184, 222, 0.06) 32px);
}

.signature-canvas {
  display: block;
  width: 100%;
  height: 210px;
  cursor: crosshair;
}

.signature-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18px;
  color: #7d94a5;
  font-size: 13px;
  text-align: center;
  pointer-events: none;
  transition: opacity 0.18s ease;
}

.signature-placeholder.hidden {
  opacity: 0;
}

.signature-actions {
  display: flex;
  justify-content: flex-end;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  padding: 14px 18px 18px;
  border-top: 1px solid rgba(88, 119, 168, 0.12);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(242, 248, 255, 0.9));
}

.detail-row {
  display: grid;
  grid-template-columns: minmax(130px, 160px) 1fr;
  gap: 10px;
  padding: 9px 0;
  border-bottom: 1px solid rgba(88, 119, 168, 0.1);
}

.detail-row .key {
  color: var(--text-muted);
  font-weight: 700;
}

.detail-row .val {
  color: var(--text);
  word-break: break-word;
}

.detail-photo {
  margin-top: 18px;
  border-radius: 24px;
  overflow: hidden;
  border: 1px solid rgba(88, 184, 222, 0.12);
  background: rgba(255, 255, 255, 0.8);
  text-align: center;
}

.detail-photo img {
  display: block;
  width: 100%;
  max-height: 420px;
  object-fit: cover;
}

.signature-photo {
  padding: 14px;
}

.signature-photo img {
  max-height: 260px;
  object-fit: contain;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(243, 251, 255, 0.9));
}

.signature-photo-label {
  padding: 0 0 12px;
  color: #22546a;
  font-size: 14px;
  font-weight: 800;
}

.upload-field {
  gap: 10px;
}

.upload-card {
  display: grid;
  gap: 12px;
  padding: 14px;
  border: 1px dashed rgba(88, 184, 222, 0.3);
  border-radius: 22px;
  background:
    linear-gradient(180deg, rgba(234, 249, 255, 0.76), rgba(255, 255, 255, 0.9)),
    linear-gradient(135deg, rgba(156, 220, 245, 0.12), transparent 45%);
}

.upload-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.upload-card-copy {
  display: grid;
  gap: 4px;
}

.upload-card-copy strong {
  color: #235b74;
  font-size: 15px;
}

.upload-card-copy small {
  color: var(--text-soft);
  line-height: 1.45;
}

.upload-chip {
  display: inline-flex;
  width: fit-content;
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(88, 184, 222, 0.14);
  color: #247398;
  font-size: 11px;
  font-weight: 800;
}

.upload-source-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.upload-choice {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4px;
  width: 100%;
  min-height: 74px;
  padding: 14px 16px;
  border: 1px solid rgba(88, 184, 222, 0.14);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.9);
  color: var(--text);
  cursor: pointer;
  text-align: right;
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.upload-choice strong {
  font-size: 14px;
}

.upload-choice small {
  color: var(--text-muted);
  font-size: 12px;
}

.upload-choice:hover {
  transform: translateY(-2px);
  border-color: rgba(88, 184, 222, 0.28);
  box-shadow: 0 12px 24px rgba(88, 184, 222, 0.1);
}

.upload-choice.primary {
  background: linear-gradient(180deg, #58b8de, #379dc8);
  color: #fff;
}

.upload-choice.primary small {
  color: rgba(255, 255, 255, 0.76);
}

.upload-preview-wrap {
  position: relative;
  min-height: 174px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22px;
  overflow: hidden;
  border: 1px solid rgba(88, 184, 222, 0.12);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(234, 249, 255, 0.92));
}

.upload-preview-glow {
  position: absolute;
  inset: auto 18% -54px 18%;
  height: 110px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(88, 184, 222, 0.16), transparent 72%);
  pointer-events: none;
}

.upload-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  color: var(--text-muted);
  text-align: center;
}

.upload-empty strong {
  color: #235b74;
}

.upload-preview {
  display: none;
  width: 100%;
  max-height: 280px;
  object-fit: cover;
}

.upload-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.upload-file-name {
  color: var(--text-soft);
  font-size: 13px;
}

.upload-clear {
  border: none;
  background: rgba(255, 255, 255, 0.82);
  color: var(--danger);
  border-radius: 999px;
  padding: 6px 12px;
  font-weight: 700;
  cursor: pointer;
}

.upload-status {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 22px;
  color: var(--text-soft);
  font-size: 13px;
}

.upload-status.error {
  color: #922f2f;
}

.upload-status.ok {
  color: #186746;
}

.spinner {
  width: 14px;
  height: 14px;
  display: inline-block;
  border: 2px solid rgba(137, 151, 161, 0.4);
  border-top-color: currentColor;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.toast-root {
  position: fixed;
  left: 50%;
  bottom: 20px;
  transform: translateX(-50%);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.toast {
  min-width: 220px;
  max-width: min(92vw, 460px);
  padding: 12px 16px;
  border-radius: 18px;
  color: #fff;
  background: rgba(31, 41, 51, 0.95);
  box-shadow: 0 16px 30px rgba(20, 26, 28, 0.2);
}

.toast.success {
  background: rgba(22, 128, 80, 0.95);
}

.toast.error {
  background: rgba(192, 61, 61, 0.96);
}

.toast.info {
  background: rgba(88, 184, 222, 0.95);
}

.print-area,
.section-card {
  padding: 14px 16px;
}

.print-area h2 {
  margin-top: 0;
}

.muted {
  color: var(--text-muted);
  font-size: 13px;
}

.activity-log-hero {
  display: grid;
  gap: 8px;
  margin-bottom: 12px;
  background:
    radial-gradient(circle at top left, rgba(246, 190, 112, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 252, 255, 0.94));
}

.activity-log-eyebrow {
  display: inline-flex;
  width: fit-content;
  padding: 6px 12px;
  border-radius: 999px;
  background: rgba(246, 190, 112, 0.16);
  color: #91541b;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.08em;
}

.activity-log-hero h3 {
  margin: 0;
  color: #22546a;
  font-size: 24px;
}

.activity-log-hero p {
  margin: 0;
  color: var(--text-soft);
  line-height: 1.7;
}

.log-toolbar {
  margin-bottom: 12px;
}

.log-summary-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 12px;
}

.log-summary-card {
  display: grid;
  gap: 6px;
}

.log-summary-card strong {
  font-size: 28px;
  color: #22546a;
}

.log-summary-card span {
  color: var(--text-soft);
  font-size: 13px;
}

.activity-log-list {
  display: grid;
  gap: 12px;
}

.log-card {
  display: grid;
  gap: 14px;
  animation: slideUp 0.28s ease both;
}

.log-card-head {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

.log-card-copy {
  display: grid;
  gap: 8px;
}

.log-card h3 {
  margin: 0;
  font-size: 20px;
  color: #214f64;
  line-height: 1.45;
}

.log-card-kicker {
  color: #7a8793;
  font-size: 12px;
  font-weight: 700;
}

.log-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.log-chip {
  display: inline-flex;
  align-items: center;
  min-height: 28px;
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(236, 247, 255, 0.96);
  color: #236682;
  font-size: 12px;
  font-weight: 700;
}

.log-chip.muted-chip {
  background: rgba(245, 247, 249, 0.96);
  color: #66727a;
}

.log-facts-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.log-fact {
  display: grid;
  gap: 4px;
  padding: 12px 14px;
  border: 1px solid rgba(88, 184, 222, 0.12);
  border-radius: 18px;
  background: rgba(248, 252, 255, 0.92);
}

.log-fact span {
  color: var(--text-muted);
  font-size: 12px;
}

.log-fact strong {
  color: #22546a;
  font-size: 14px;
}

.log-detail-list {
  display: grid;
  gap: 8px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.log-detail-list li {
  position: relative;
  padding: 10px 14px 10px 10px;
  border-radius: 16px;
  background: rgba(245, 249, 252, 0.92);
  color: var(--text-soft);
  line-height: 1.6;
}

.log-detail-list li::before {
  content: "";
  position: absolute;
  inset-inline-start: 0;
  top: 10px;
  bottom: 10px;
  width: 4px;
  border-radius: 999px;
  background: linear-gradient(180deg, rgba(88, 184, 222, 0.94), rgba(36, 115, 152, 0.72));
}

.log-empty-state {
  text-align: center;
}

.log-empty-state strong {
  display: block;
  margin-bottom: 6px;
  color: #22546a;
}

.actions-cell {
  white-space: normal;
}

.flex {
  display: flex;
}

.gap-8 {
  gap: 8px;
}

.gap-12 {
  gap: 12px;
}

.center {
  align-items: center;
}

.wrap {
  flex-wrap: wrap;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

hr.sep {
  margin: 16px 0;
  border: none;
  border-top: 1px solid rgba(88, 119, 168, 0.14);
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(14px) scale(0.985);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@media (max-width: 900px) {
  .page-title {
    flex-direction: column;
    align-items: stretch;
  }

  .home-actions {
    justify-content: stretch;
  }

  .home-actions .btn {
    flex: 1 1 180px;
  }

  .toolbar input[type="text"],
  .toolbar input[type="date"] {
    max-width: none;
  }

  .log-summary-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  .topbar {
    padding: 12px 16px;
    grid-template-columns: 1fr;
    justify-items: stretch;
  }

  .topbar-spacer {
    display: none;
  }

  .topbar-center,
  .topbar-left {
    justify-content: center;
  }

  .app {
    padding: 18px 14px 28px;
  }

  .home-hero {
    min-height: 240px;
    border-radius: 28px;
  }

  .hero-overlay {
    align-items: center;
    padding: 24px;
    justify-content: center;
    text-align: center;
  }

  .hero-content h2 {
    font-size: 32px;
  }

  .hero-content p {
    font-size: 15px;
    margin: 0 auto;
  }

  .home-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  table.data.responsive-table {
    min-width: 0;
  }

  table.data.responsive-table thead {
    display: none;
  }

  table.data.responsive-table,
  table.data.responsive-table tbody,
  table.data.responsive-table tr,
  table.data.responsive-table td {
    display: block;
    width: 100%;
  }

  table.data.responsive-table tbody {
    display: grid;
    gap: 12px;
  }

  table.data.responsive-table tbody tr {
    padding: 12px 14px;
    border: 1px solid rgba(88, 119, 168, 0.12);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: var(--shadow-sm);
    animation: slideUp 0.24s ease both;
  }

  table.data.responsive-table tbody tr:nth-child(even) {
    background: rgba(248, 252, 255, 0.96);
  }

  table.data.responsive-table td {
    display: grid;
    grid-template-columns: minmax(92px, 104px) 1fr;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px dashed rgba(88, 119, 168, 0.12);
    text-align: right;
    white-space: normal;
  }

  table.data.responsive-table td:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  table.data.responsive-table td::before {
    content: attr(data-label);
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 800;
  }

  .actions-cell {
    display: flex !important;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .actions-cell::before {
    width: 100%;
  }

  .log-facts-grid {
    grid-template-columns: 1fr;
  }

  .modal,
  .modal.large {
    max-width: 100%;
    border-radius: 22px;
  }

  .modal-header,
  .modal-body,
  .modal-footer {
    padding-inline: 14px;
  }

  .signature-pad-shell,
  .signature-canvas {
    min-height: 180px;
    height: 180px;
  }

  .upload-source-actions {
    grid-template-columns: 1fr;
  }

  .detail-row {
    grid-template-columns: 1fr;
    gap: 4px;
  }
}

@media (max-width: 520px) {

  #homeBtn {
    display: none;
  }

  .topbar {
    padding: 10px 16px;
    gap: 12px;
  }

  .topbar-center,
  .topbar-left {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    width: 100%;
  }

  .brand {
    font-size: 18px;
    text-align: right;
    margin-inline-end: auto;
  }

  .user-greeting {
    padding: 4px 10px;
